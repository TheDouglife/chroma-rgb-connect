<div class="device-view">
    <div class="device-view-container">
        <div class="device-view-header">
            Devices <span class="device-count">@_devices.Count</span>
        </div>
        <div class="device-view-list">
            <CascadingValue Value="this" Name="DeviceView" IsFixed="true">
                @for (var i = 0; i < _devices.Count; i++)
                {
                    <Device DefaultItem="i == 0" Index="@_devices[i].Index" Name="@_devices[i].Name" />
                }
            </CascadingValue>
        </div>
    </div>
    <div class="device-settings-container">
        @if (_activeDevice != null)
        {
            <div class="device-settings-wrapper">
                <div class="device-summary">
                    <div class="device-summary-copy">
                        <div class="device-summary-name">
                            <span>@_activeDevice.Name</span>
                        </div>
                        <div class="device-summary-details">
                            <span>Detected</span> &bull; <span>Select a section to configure this device</span>
                        </div>
                    </div>
                </div>
                <DeviceSettings DeviceIndex="_activeDevice.Index" />
            </div>
        }
    </div>
</div>
